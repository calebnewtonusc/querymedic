# ─── Required ─────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Stack Exchange ───────────────────────────────────────────────────────────
STACKOVERFLOW_KEY=your_key_here

# ─── Database Connections (validation agent) ──────────────────────────────────
POSTGRES_URL=postgresql://localhost:5432/querymedic_test
MYSQL_URL=mysql://root:@localhost:3306/querymedic_test

# ─── vLLM ─────────────────────────────────────────────────────────────────────
VLLM_API_KEY=querymedic-secret
VLLM_URLS=http://localhost:8001,http://localhost:8002

# ─── Optional ─────────────────────────────────────────────────────────────────
WANDB_API_KEY=
WANDB_PROJECT=querymedic
HF_TOKEN=

# ─── Validation Thresholds ────────────────────────────────────────────────────
MIN_TIMING_IMPROVEMENT=1.1     # At least 10% faster EXPLAIN ANALYZE timing
MAX_INDEX_COUNT=3              # Max indexes per recommendation
MAX_STORAGE_MB=1000            # Default storage budget for index recommendations
